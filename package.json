{
  "name": "rocketh-monorepo",
  "private": true,
  "version": "0.5.0",
  "homepage": "https://github.com/wighawag/rocketh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wighawag/rocketh.git"
  },
  "bugs": {
    "url": "https://github.com/wighawag/rocketh/issues"
  },
  "type": "module",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@nx/js": "^22.6.5",
    "@types/node": "^25.6.0",
    "dorfl": "0.8.0",
    "ezx": "^0.0.18",
    "nx": "^22.6.5",
    "prettier": "^3.8.3",
    "set-defaults": "^0.0.5",
    "syncpack": "^14.3.0",
    "tsx": "^4.21.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.10",
    "zellij-launcher": "^0.0.1"
  },
  "volta": {
    "node": "22.14.0"
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "comment": "Force-patch transitive dev/test/docs tooling deps flagged by Dependabot. None of these are runtime deps of the published @rocketh/* packages; they come in via vitepress, hardhat and vitest. Ranges are pinned to just above each advisory's vulnerable range.",
    "overrides": {
      "axios@>=1.0.0 <1.18.0": "^1.18.0",
      "vite@>=5.2.6 <5.4.21": "^5.4.21",
      "vite@>=7.0.0 <7.3.5": "^7.3.5",
      "esbuild@<0.25.0": "^0.25.0",
      "esbuild@>=0.27.3 <0.28.1": "^0.28.1",
      "ws@>=8.0.0 <8.21.0": "^8.21.0",
      "adm-zip@<0.6.0": "^0.6.0",
      "@tootallnate/once@<2.0.1": "^2.0.1",
      "form-data@>=4.0.0 <4.0.6": "^4.0.6",
      "brace-expansion@>=3.0.0 <5.0.7": "^5.0.7",
      "tmp@<0.2.6": "^0.2.6",
      "postcss@<8.5.10": "^8.5.10",
      "rollup@>=4.0.0 <4.59.0": "^4.59.0",
      "preact@>=10.27.0 <10.27.3": "^10.27.3",
      "mdast-util-to-hast@>=13.0.0 <13.2.1": "^13.2.1",
      "@babel/core@<=7.29.0": "^7.29.6",
      "@babel/plugin-transform-modules-systemjs@>=7.12.0 <=7.29.3": "^7.29.4",
      "@koa/cors@<5.0.0": "^5.0.0"
    }
  },
  "scripts": {
    "prepare": "set-defaults .vscode",
    "prepublishOnly": "pnpm format:check && pnpm build",
    "release": "pnpm prepublishOnly && git push --all && pnpm changeset publish && git push --tags",
    "release:ci": "pnpm prepublishOnly && pnpm changeset publish",
    "changeset:force-patch": "tsx scripts/force-patch-changesets.ts",
    "changeset:version": "pnpm changeset:force-patch && pnpm changeset version",
    "reset": "git clean -fdX; pnpm i",
    "sync-deps": "syncpack fix-mismatches",
    "docs:dev": "vitepress dev",
    "docs:build": "pnpm prepare && vitepress build",
    "docs:preview": "vitepress preview",
    "typecheck": "pnpm -r --parallel exec tsc --noEmit",
    "test:getting-started": "ezx --verbose README.md -s 'Getting Started' && rm -Rf my-rocketh-project",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\"",
    "build": "nx run-many -t build",
    "start": "nx run-many -t dev"
  }
}
